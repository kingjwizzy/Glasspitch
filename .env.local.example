# Glass Pitch — web app environment.
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# NEXT_PUBLIC_* values are exposed to the browser; everything else is server-only
# (ARCHITECTURE.md §12).

# Supabase project URL (public), e.g. https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable key (public; read-only via Row Level Security).
# New-style key, format: sb_publishable_...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
#
# The web app must NEVER hold SUPABASE_SECRET_KEY (bypasses RLS) or
# API_FOOTBALL_KEY (the football API is only ever called by jobs/ — §5 golden
# rule) — deliberately not templated here so neither is ever pasted into the
# production deployment's env. src/lib/supabaseAdmin.ts (server-only, guarded by
# `import "server-only"`) reads SUPABASE_SECRET_KEY when it is actually needed
# (e.g. a future W2 webhook writer) — set it directly in that environment only,
# never in this shared template.

# Public base URL of the deployed site — used for metadata, Open Graph, sitemap
# and robots. Falls back to http://localhost:3000 in dev/test; a real
# production deploy with this unset fails at build/module-load instead of
# silently emitting localhost (see src/lib/constants.ts).
NEXT_PUBLIC_SITE_URL=

# Season floor for every web read that renders predictions/fixtures as "the
# record" (ledger, homepage, team/league fixture lists, match lookups, the
# sitemap). Defence in depth against dev-seed data (from a season before the
# live tournament) ever rendering as the genuine public record. Defaults to
# 2026 (the live FIFA World Cup season, jobs/config.py's LIVE_SEASON) if unset.
NEXT_PUBLIC_MIN_SEASON=

# --- Dev/preview-only fixture hatches (server-only; NEVER set in production) -
# Each PREVIEW_* var fabricates representative in-memory data for its page with
# no seeded database (see src/lib/queries/*.preview.ts) — useful for local dev
# and screenshotting, but they write NOTHING and must never activate on a real
# deploy. Both a PREVIEW_* var AND ALLOW_PREVIEW=1 are required together (a
# single stray PREVIEW_* var alone does nothing) — this repo's own e2e suite
# sets both in playwright.config.ts's webServer env, since it deliberately runs
# a production build.
#
# ALLOW_PREVIEW=1                enables ALL PREVIEW_* vars below
# PREVIEW_HOMEPAGE=1|default|live|empty
# PREVIEW_LEDGER=1|default|empty
# PREVIEW_MATCH=<any value>      (renders a fixed set of illustrative match ids)
# PREVIEW_TEAM=1|default|empty
# PREVIEW_LEAGUE=1|default|empty
ALLOW_PREVIEW=
PREVIEW_HOMEPAGE=
PREVIEW_LEDGER=
PREVIEW_MATCH=
PREVIEW_TEAM=
PREVIEW_LEAGUE=

# --- Stripe (v2 premium; test-mode keys until vetting/legal sign-off) --------
# Dashboard → Developers → API keys (test mode). Keys go in .env.local locally
# and in Vercel project env vars in production — never in the repo.
# Checkout is Stripe-HOSTED (a server-issued redirect) so the public surface
# stays zero-client-JS — no @stripe/stripe-js is used, so nothing in src/
# actually reads NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY yet; it's templated for
# whenever a client-side Stripe.js/Elements surface is genuinely needed.

# Publishable key (public, safe in the browser). Format: pk_test_/pk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Server key (SECRET — server-only). Prefer a restricted key (rk_...) scoped to
# Checkout Sessions, Customer portal, Customers (write) + Subscriptions,
# Products, Prices (read), per Stripe key best practices.
STRIPE_SECRET_KEY=

# Webhook signing secret (whsec_...) for the Stripe webhook route — used to
# verify event signatures. Created with the webhook endpoint. May be empty
# pre-launch: the webhook route responds 503 + logs rather than crashing.
STRIPE_WEBHOOK_SECRET=

# Price ids for the two locked plans (£4/month, £29/year — ARCHITECTURE.md
# §4). Dashboard → Product catalog. May be empty pre-launch: /premium then
# shows an honest "checkout isn't switched on yet" message instead of a
# button, and /api/stripe/checkout responds 503 + logs rather than crashing.
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_ANNUAL=
