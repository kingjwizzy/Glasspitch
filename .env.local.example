# Glass Pitch — web app environment.
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# NEXT_PUBLIC_* values are exposed to the browser; everything else is server-only
# (ARCHITECTURE.md §12).

# Supabase project URL (public), e.g. https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon / public key (public; read-only via Row Level Security).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key (SECRET — bypasses RLS). Server-only; never exposed
# to the browser. Used only by server-side code (see src/lib/supabaseAdmin.ts).
SUPABASE_SERVICE_ROLE_KEY=

# API-Football key (SECRET). The website never calls the API on the request path
# (§5 golden rule); present only if a server route ever needs it.
API_FOOTBALL_KEY=

# Public base URL of the deployed site — used for metadata, Open Graph, sitemap
# and robots. Falls back to http://localhost:3000 if unset.
NEXT_PUBLIC_SITE_URL=
