# Glass Pitch — Python jobs environment.
# Copy to jobs/.env and fill in real values. NEVER commit jobs/.env.
# These jobs are the ONLY writers to the database and the ONLY callers of the
# football API (ARCHITECTURE.md §5, §6).

# Supabase project URL, e.g. https://YOUR-PROJECT-REF.supabase.co
SUPABASE_URL=

# Supabase secret key (SECRET — bypasses Row Level Security; server-side only).
# New-style key, format: sb_secret_...
SUPABASE_SECRET_KEY=

# API-Football key (SECRET).
API_FOOTBALL_KEY=

# --- Tracked competition (OPTIONAL overrides; live defaults are committed) ----
# The jobs default to FIFA World Cup 2026 (league 1, season 2026). Override these
# for a DEV seed only — e.g. the 2022 Qatar World Cup, the only World Cup the free
# API plan can read. Going live = remove them (or set 2026 / 1). See docs/SEEDING.md.
# WC_LEAGUE_ID=1
# WC_SEASON=2022

# --- Scale / robustness knobs (OPTIONAL overrides; sane defaults are committed) --
# How far ahead (hours) fetch_predictions looks for fixtures to fetch a
# third-party prediction for. Default 72.
# PREDICTION_FETCH_WINDOW_HOURS=72
# How many days a 'postponed' fixture can sit with no reschedule before
# fetch_fixtures closes out its open predictions as void_cancelled. Default 45.
# POSTPONED_VOID_HORIZON_DAYS=45
# Monte Carlo trial count for simulate_chances.py. Default 10000.
# MONTE_CARLO_SIMS=10000
# Private Supabase Storage bucket ledger_integrity.py exports backups into.
# Default ledger-backups.
# LEDGER_BACKUPS_BUCKET=ledger-backups
