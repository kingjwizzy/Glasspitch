# Glass Pitch — Python jobs environment.
# Copy to jobs/.env and fill in real values. NEVER commit jobs/.env.
# These jobs are the ONLY writers to the database and the ONLY callers of the
# football API (ARCHITECTURE.md §5, §6).

# Supabase project URL, e.g. https://YOUR-PROJECT-REF.supabase.co
SUPABASE_URL=

# Supabase secret key (SECRET — bypasses Row Level Security; server-side only).
# New-style key, format: sb_secret_...
SUPABASE_SECRET_KEY=

# API-Football key (SECRET).
API_FOOTBALL_KEY=
